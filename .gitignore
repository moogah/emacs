org-roam.db
# Machine-specific
.machine-role

# Runtime - mostly ignored
runtime/custom.el
runtime/data/*
runtime/cache/*
runtime/state/*
runtime/packages/*

# Keep structure
!runtime/data/.gitkeep
!runtime/cache/.gitkeep
!runtime/state/.gitkeep
!runtime/packages/.gitkeep

# State files - machine-specific, ephemeral session data
# Keep directory structure and READMEs only
state/**
!state/**/
!state/**/README.md

# Emacs temp files
*.elc
*.eln
*~
\#*\#
.\#*

# OS
.DS_Store

# worktrees
.worktrees/
